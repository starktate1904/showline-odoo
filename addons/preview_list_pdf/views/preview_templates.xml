<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_landscape" model="report.paperformat">
        <field name="name">Preview Landscape A4</field>
        <field name="format">A4</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">5</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_preview_list_pdf" model="ir.actions.report">
        <field name="name">Preview List PDF</field>
        <field name="model">ir.model</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">preview_list_pdf.report_preview_list_pdf</field>
        <field name="report_file">preview_list_pdf.report_preview_list_pdf</field>
        <field name="print_report_name">'List Preview'</field>
        <field name="paperformat_id" ref="preview_list_pdf.paperformat_landscape"/>
    </record>

    <template id="report_preview_list_pdf">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <div class="mb-3">
                        <h3 t-esc="data.get('model_name', 'List Preview')"/>
                        <p class="text-muted small">
                            <strong>Company:</strong>
                            <t t-esc="data.get('company_name', '')"/>
                            <t t-if="data.get('total_records', 0) > 0">
                                | <strong>Showing:</strong>
                                <t t-esc="data.get('showing_from')"/> - <t t-esc="data.get('showing_to')"/>
                                of <t t-esc="data.get('total_records')"/>
                                | <strong>Page:</strong>
                                <t t-esc="data.get('page_number')"/> / <t t-esc="data.get('total_pages')"/>
                            </t>
                        </p>
                    </div>

                    <t t-foreach="data.get('table_chunks', [])" t-as="chunk">
                        <table class="table table-sm table-bordered" style="font-size: 8px; width: 100%; table-layout: fixed;">
                            <thead>
                                <tr style="background-color: #f8f9fa;">
                                    <th t-foreach="chunk.get('headers', [])" t-as="header" style="padding: 4px 6px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        <t t-esc="header"/>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="chunk.get('rows', [])" t-as="row">
                                    <td t-foreach="row" t-as="cell" style="padding: 3px 6px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        <t t-esc="cell"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </t>
                    <t t-if="not data.get('rows')">
                        <p class="text-center text-muted py-5">No records to display.</p>
                    </t>
                </div>
            </t>
        </t>
    </template>
</odoo>
