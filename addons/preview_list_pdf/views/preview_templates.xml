<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_preview_list_pdf" model="ir.actions.report">
        <field name="name">Preview List PDF</field>
        <field name="model">ir.model</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">preview_list_pdf.report_preview_list_pdf</field>
        <field name="report_file">preview_list_pdf.report_preview_list_pdf</field>
        <field name="print_report_name">'List Preview'</field>
    </record>

    <template id="report_preview_list_pdf">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>
                        <span t-esc="data.get('model_name', 'List Preview')"/>
                    </h2>
                    <p>
                        <strong>Company:</strong>
                        <span t-esc="data.get('company_name', '')"/>
                    </p>
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th t-foreach="data.get('headers', [])" t-as="header">
                                    <span t-esc="header"/>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="data.get('rows', [])" t-as="row">
                                <td t-foreach="row" t-as="cell">
                                    <span t-esc="cell"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
