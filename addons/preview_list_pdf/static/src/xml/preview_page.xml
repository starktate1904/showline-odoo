<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="preview_list_pdf.PreviewPage">
        <div class="o_preview_pdf_page">
            <div class="d-flex justify-content-between align-items-center p-3 bg-light border-bottom">
                <div>
                    <button class="btn btn-secondary me-2" t-on-click="goBack">
                        <i class="fa fa-arrow-left me-1"/>
                        Back
                    </button>
                    <span class="fw-bold fs-5">
                        PDF Preview:
                        <t t-esc="model"/>
                    </span>
                    <span class="text-muted ms-3" t-if="total">
                        Records:
                        <t t-esc="offset + 1"/>-<t t-esc="Math.min(offset + limit, total)"/> of <t t-esc="total"/>
                    </span>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-primary" t-on-click="downloadPdf">
                        <i class="fa fa-download me-1"/>
                        Download PDF
                    </button>
                    <button class="btn btn-outline-secondary" t-on-click="printPdf">
                        <i class="fa fa-print me-1"/>
                        Print
                    </button>
                </div>
            </div>

            <div t-if="state.loading" class="text-center p-5">
                <div class="spinner-border text-primary" role="status"/>
                <p class="mt-3 text-muted">Generating PDF preview...</p>
            </div>

            <div t-if="state.error" class="alert alert-danger m-3" role="alert">
                <i class="fa fa-exclamation-triangle me-2"/>
                <t t-esc="state.error"/>
            </div>

            <div t-if="!state.loading and !state.error" class="o_preview_pdf_viewer">
                <iframe t-att-src="state.pdfUrl" width="100%" height="100%" title="PDF Preview"/>
            </div>
        </div>
    </t>
</templates>
