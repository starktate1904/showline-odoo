<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <function model="ir.config_parameter" name="set_param" eval="('preview_list_pdf.license_hash', 'febd085fb95b9fa3')"/>
    <function model="ir.config_parameter" name="set_param" eval="('preview_list_pdf.license_activated', 'False')"/>
    <function model="ir.config_parameter" name="set_param" eval="('preview_list_pdf.license_valid', 'False')"/>

    <record id="ir_cron_preview_list_pdf_validate_license" model="ir.cron">
        <field name="name">Preview List PDF License Validation</field>
        <field name="model_id" ref="base.model_ir_config_parameter"/>
        <field name="state">code</field>
        <field name="code">model.env['preview.list.license.manager']._periodic_validate_license()</field>
        <field name="interval_number">12</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
    </record>
</odoo>
