<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_havano_api_documentation_form" model="ir.ui.view">
        <field name="name">havano.api.documentation.form</field>
        <field name="model">havano.api.documentation</field>
        <field name="arch" type="xml">
            <form string="Havano API Documentation" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <field name="title" readonly="1"/>
                    </group>
                    <field name="content" widget="html" nolabel="1" readonly="1"/>
                </sheet>
                <footer>
                    <button string="Close" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_havano_api_documentation" model="ir.actions.act_window">
        <field name="name">Documentation</field>
        <field name="res_model">havano.api.documentation</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>
</odoo>
