<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_css_license" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.css.license</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Customer Supplier Separation License" name="customer_supplier_separation_license_app">
                    <block title="License">
                        <setting>
                            <field name="css_license_key" placeholder="XXXX-XXXX-XXXX-XXXX"/>
                            <field name="css_license_valid" readonly="1"/>
                            <button name="action_activate_customer_supplier_separation_license" type="object" string="Activate License" class="btn btn-primary"/>
                            <div class="alert alert-warning mt16" invisible="css_license_valid">
                                <strong>Unlicensed:</strong> Customer/Supplier separation restrictions are inactive.
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
