<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_css_settings" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.css.settings</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Customer Supplier Separation" name="customer_supplier_separation_app">
                    <block title="Behavior">
                        <setting><field name="show_only_customers_in_sales"/></setting>
                        <setting><field name="show_only_suppliers_in_purchases"/></setting>
                        <setting><field name="auto_mark_customer_from_sales"/></setting>
                        <setting><field name="auto_mark_supplier_from_purchase"/></setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
