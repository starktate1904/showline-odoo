<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <function model="ir.config_parameter" name="set_param" eval="('customer_supplier_separation.license_hash', '291d229f7d902d2f')"/>
    <function model="ir.config_parameter" name="set_param" eval="('customer_supplier_separation.license_activated', 'False')"/>
    <function model="ir.config_parameter" name="set_param" eval="('customer_supplier_separation.license_valid', 'False')"/>

    <record id="ir_cron_css_validate_license" model="ir.cron">
        <field name="name">Customer Supplier Separation License Validation</field>
        <field name="model_id" ref="base.model_ir_config_parameter"/>
        <field name="state">code</field>
        <field name="code">model.env['cust.supp.license.manager']._periodic_validate_license()</field>
        <field name="interval_number">12</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
    </record>
</odoo>
