<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Gross Salary (Computed) -->
        <record id="zim_rule_gross" model="hr.salary.rule">
            <field name="name">Gross Salary</field>
            <field name="code">GROSS</field>
            <field name="sequence">100</field>
            <field name="category_id" ref="zim_category_gross"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = categories.BASIC + categories.ALLOW</field>
            <field name="appears_on_payslip">True</field>
            <field name="active">True</field>
        </record>
        
        <!-- NSSA Employee -->
        <record id="zim_rule_nssa_employee" model="hr.salary.rule">
            <field name="name">NSSA (Employee)</field>
            <field name="code">NSSA_EE</field>
            <field name="sequence">110</field>
            <field name="category_id" ref="zim_category_nssa"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute"><![CDATA[
# NSSA Employee Contribution
# 4.5% of insurable earnings (capped at $700 USD)
insurable = min(categories.BASIC + categories.ALLOW, 700.0)
result = - (insurable * 0.045)
]]></field>
            <field name="appears_on_payslip">True</field>
            <field name="active">True</field>
        </record>
        
        <!-- Pension -->
        <record id="zim_rule_pension" model="hr.salary.rule">
            <field name="name">Pension Contribution</field>
            <field name="code">PENSION</field>
            <field name="sequence">120</field>
            <field name="category_id" ref="zim_category_pension"/>
            <field name="condition_select">none</field>
            <field name="amount_select">fix</field>
            <field name="amount_fix">0.0</field>
            <field name="appears_on_payslip">True</field>
            <field name="active">True</field>
        </record>
        
        <!-- Medical Aid -->
        <record id="zim_rule_medical" model="hr.salary.rule">
            <field name="name">Medical Aid</field>
            <field name="code">MEDICAL</field>
            <field name="sequence">130</field>
            <field name="category_id" ref="zim_category_medical"/>
            <field name="condition_select">none</field>
            <field name="amount_select">fix</field>
            <field name="amount_fix">0.0</field>
            <field name="appears_on_payslip">True</field>
            <field name="active">True</field>
        </record>
        
        <!-- NEC -->
        <record id="zim_rule_nec" model="hr.salary.rule">
            <field name="name">NEC Contribution</field>
            <field name="code">NEC</field>
            <field name="sequence">140</field>
            <field name="category_id" ref="zim_category_nec"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute"><![CDATA[
# NEC = 1.5% of Basic Salary
result = - (categories.BASIC * 0.015)
]]></field>
            <field name="appears_on_payslip">True</field>
            <field name="active">True</field>
        </record>
        
        <!-- Taxable Income (Computed) -->
        <record id="zim_rule_taxable" model="hr.salary.rule">
            <field name="name">Taxable Income</field>
            <field name="code">TAXABLE</field>
            <field name="sequence">150</field>
            <field name="category_id" ref="zim_category_taxable"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute"><![CDATA[
# Taxable Income = Gross - NSSA - Pension (capped at $250)
pension_deduction = min(abs(categories.PENSION), 250.0)
result = categories.GROSS - abs(categories.NSSA_EE) - pension_deduction
]]></field>
            <field name="appears_on_payslip">False</field>
            <field name="active">True</field>
        </record>
        
        <!-- PAYE - Updated with Frequency Detection -->
        <record id="zim_rule_paye" model="hr.salary.rule">
            <field name="name">PAYE</field>
            <field name="code">PAYE</field>
            <field name="sequence">160</field>
            <field name="category_id" ref="zim_category_tax"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute"><![CDATA[
# ZIMRA PAYE Calculation using Tax Tables
taxable = categories.TAXABLE

# Get the pay frequency from the contract
# Map contract.schedule_pay to tax table frequency
freq_map = {
    'daily': 'daily',
    'weekly': 'weekly', 
    'bi-weekly': 'fortnightly',
    'fortnightly': 'fortnightly',
    'monthly': 'monthly',
}
frequency = freq_map.get(contract.schedule_pay, 'monthly')

# Find applicable tax bracket
tax_bracket = env['zim.tax.table'].search([
    ('currency_id', '=', payslip.company_id.currency_id.id),
    ('frequency', '=', frequency),
    ('min_income', '<=', taxable),
    '|', ('max_income', '>=', taxable), ('max_income', '=', 0),
    ('effective_date', '<=', payslip.date_from),
    ('active', '=', True),
], limit=1, order='effective_date desc, min_income desc')

if tax_bracket:
    tax = (taxable * tax_bracket.rate / 100.0) - tax_bracket.deduction
    tax = max(tax, 0)
else:
    tax = 0

# Apply tax credits (from employee)
# tax = max(tax - employee.tax_credits, 0)

result = - max(tax, 0)
]]></field>
            <field name="appears_on_payslip">True</field>
            <field name="active">True</field>
        </record>
        
        <!-- AIDS Levy -->
        <record id="zim_rule_aids" model="hr.salary.rule">
            <field name="name">AIDS Levy</field>
            <field name="code">AIDS</field>
            <field name="sequence">170</field>
            <field name="category_id" ref="zim_category_tax"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute"><![CDATA[
# AIDS Levy = 3% of PAYE
result = categories.PAYE * 0.03
]]></field>
            <field name="appears_on_payslip">True</field>
            <field name="active">True</field>
        </record>
        
        <!-- Loan Repayment -->
        <record id="zim_rule_loan" model="hr.salary.rule">
            <field name="name">Loan Repayment</field>
            <field name="code">LOAN</field>
            <field name="sequence">180</field>
            <field name="category_id" ref="zim_category_loans"/>
            <field name="condition_select">none</field>
            <field name="amount_select">fix</field>
            <field name="amount_fix">0.0</field>
            <field name="appears_on_payslip">True</field>
            <field name="active">True</field>
        </record>
        
        <!-- Union Fees -->
        <record id="zim_rule_union" model="hr.salary.rule">
            <field name="name">Trade Union Fees</field>
            <field name="code">UNION</field>
            <field name="sequence">190</field>
            <field name="category_id" ref="zim_category_loans"/>
            <field name="condition_select">none</field>
            <field name="amount_select">fix</field>
            <field name="amount_fix">0.0</field>
            <field name="appears_on_payslip">True</field>
            <field name="active">True</field>
        </record>
        
        <!-- NSSA Employer -->
        <record id="zim_rule_nssa_employer" model="hr.salary.rule">
            <field name="name">NSSA (Employer)</field>
            <field name="code">NSSA_ER</field>
            <field name="sequence">200</field>
            <field name="category_id" ref="zim_category_employer"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute"><![CDATA[
# NSSA Employer Contribution (4.5% capped at $700)
insurable = min(categories.BASIC + categories.ALLOW, 700.0)
result = insurable * 0.045
]]></field>
            <field name="appears_on_payslip">True</field>
            <field name="active">True</field>
        </record>
        
        <!-- Net Salary -->
        <record id="zim_rule_net" model="hr.salary.rule">
            <field name="name">Net Salary</field>
            <field name="code">NET</field>
            <field name="sequence">210</field>
            <field name="category_id" ref="zim_category_net"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute"><![CDATA[
# Net = Gross + All Deductions (which are negative values)
result = categories.GROSS + categories.NSSA_EE + categories.PENSION + categories.MEDICAL + categories.NEC + categories.PAYE + categories.AIDS + categories.LOAN + categories.UNION
]]></field>
            <field name="appears_on_payslip">True</field>
            <field name="active">True</field>
        </record>
        
    </data>
</odoo>