<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Employee View - Add Smart Button -->
    <record id="payroll_hr_employee_view_form" model="ir.ui.view">
        <field name="name">payroll.hr.employee.view.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="%(act_hr_employee_payslip_list)d"
                    class="oe_stat_button"
                    icon="fa-money"
                    type="action"
                    groups="bi_hr_payroll.group_hr_payroll_user">
                    <field name="payslip_count" widget="statinfo" string="Payslips"/>
                </button>
            </div>
        </field>
    </record>

    <!-- Add ZIM Fields to Employee Form -->
    <record id="view_hr_employee_form_zim_fields" model="ir.ui.view">
        <field name="name">hr.employee.form.zim.fields</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <page name="work_information" position="after">
                <page string="ZIM Payroll" name="zim_payroll">
                    <group string="Tax Information">
                        <group>
                            <field name="tin_number"/>
                            <field name="nssa_number"/>
                            <field name="ec_number"/>
                            <field name="national_id"/>
                        </group>
                        <group>
                            <field name="is_blind"/>
                            <field name="is_elderly"/>
                            <field name="is_disabled"/>
                            <field name="medical_aid_contributor"/>
                            <field name="medical_aid_amount" 
                                   invisible="not medical_aid_contributor"/>
                            <field name="total_tax_credits" readonly="1"/>
                        </group>
                    </group>
                </page>
            </page>
        </field>
    </record>

    <!-- REMOVED: Salary Details Tab - contract_id doesn't exist on hr.employee -->
    <!-- The Salary Details can be viewed on the Contract itself -->

</odoo>