<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Payslip Line Tree View -->
    <record id="view_hr_payslip_line_tree" model="ir.ui.view">
        <field name="name">hr.payslip.line.tree</field>
        <field name="model">hr.payslip.line</field>
        <field name="arch" type="xml">
            <list string="Salary Structure" editable="bottom" decoration-info="total == 0">
                <field name="employee_id" invisible="1"/>
                <field name="sequence" invisible="1"/>
                <field name="salary_rule_id" invisible="1"/>
                <field name="amount_select" invisible="1"/>
                <field name="register_id" invisible="1"/>
                
                <field name="category_id" optional="hide"/>
                <field name="code"/>
                <field name="name"/>
                <field name="quantity"/>
                <field name="rate"/>
                <field name="amount"/>
                <field name="total" sum="Total"/>
            </list>
        </field>
    </record>

    <!-- Payslip Line Form View -->
    <record id="view_hr_payslip_line_form" model="ir.ui.view">
        <field name="name">hr.payslip.line.form</field>
        <field name="model">hr.payslip.line</field>
        <field name="arch" type="xml">
            <form string="Payslip Line">
                <group>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="slip_id" invisible="1"/>
                        <field name="employee_id"/>
                    </group>
                    <group string="Calculations">
                        <field name="category_id"/>
                        <field name="amount_select"/>
                        <field name="amount_fix" invisible="amount_select != 'fix'"/>
                        <field name="amount_percentage" invisible="amount_select != 'percentage'"/>
                        <field name="sequence" invisible="1"/>
                    </group>
                    <field name="note"/>
                </group>
            </form>
        </field>
    </record>

    <!-- Payslip Line Search View -->
    <record id="view_hr_payslip_line_filter" model="ir.ui.view">
        <field name="name">hr.payslip.line.select</field>
        <field name="model">hr.payslip.line</field>
        <field name="arch" type="xml">
            <search string="Search Payslip Lines">
                <field name="name" string="Payslip Lines" filter_domain="['|',('name','ilike',self),('code','ilike',self)]"/>
                <field name="amount_select"/>
                <field name="slip_id"/>
                <filter string="Salary Rule Category" name="category_id" context="{'group_by':'category_id'}"/>
                <filter string="Contribution Register" name="register_id" context="{'group_by':'register_id'}"/>
                <filter string="Amount Type" name="amount_select" context="{'group_by':'amount_select'}"/>
                <filter string="Employees" name="employee_id" context="{'group_by':'employee_id'}"/>
            </search>
        </field>
    </record>

    <!-- Payslip Tree View -->
    <record id="view_hr_payslip_tree" model="ir.ui.view">
        <field name="name">hr.payslip.tree</field>
        <field name="model">hr.payslip</field>
        <field name="arch" type="xml">
            <list string="Payslips">
                <field name="number"/>
                <field name="employee_id"/>
                <field name="name"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="state" widget="badge" 
                       decoration-success="state == 'done'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state == 'cancel'"/>
                <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                <field name="payslip_run_id" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Payslip Kanban View -->
    <record id="hr_payslip_view_kanban" model="ir.ui.view">
        <field name="name">hr.payslip.kanban</field>
        <field name="model">hr.payslip</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_content oe_kanban_global_click">
                            <div class="row">
                                <div class="col-6">
                                    <strong><field name="employee_id"/></strong>
                                </div>
                                <div class="col-6">
                                    <span class="float-right badge badge-secondary">
                                        <field name="state"/>
                                    </span>
                                </div>
                                <div class="col-12">
                                    <span>
                                        <field name="date_from"/> - <field name="date_to"/>
                                    </span>
                                </div>
                                <div class="col-12">
                                    <span><field name="name"/></span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Payslip Form View -->
    <record id="view_hr_payslip_form" model="ir.ui.view">
        <field name="name">hr.payslip.form</field>
        <field name="model">hr.payslip</field>
        <field name="arch" type="xml">
            <form string="Payslip">
                <header>
                    <button string="Compute Sheet" name="compute_sheet" type="object" 
                            invisible="state != 'draft'" class="oe_highlight"/>
                    <button string="Confirm" name="action_payslip_done" type="object" 
                            invisible="state != 'draft'" class="oe_highlight"/>
                    <button string="Refund" name="refund_sheet" 
                            invisible="state != 'done'" type="object"/>
                    <button string="Set to Draft" name="action_payslip_draft" type="object" 
                            invisible="state != 'cancel'"/>
                    <button string="Cancel Payslip" name="action_payslip_cancel" type="object" 
                            invisible="state == 'done' or state == 'cancel'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" name="payslip_line_count" type="object" icon="fa-money" invisible="payslip_count == 0"> 
                            <field name="payslip_count" widget="statinfo" string="Lines"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="employee_id" class="oe_edit_only"/>
                        <h1><field name="employee_id" placeholder="Employee" readonly="state != 'draft'"/></h1>
                    </div>
                    <group col="4">
                        <label for="date_from" string="Period"/>
                        <div>
                            <field name="date_from" class="oe_inline" readonly="state != 'draft'"/> - 
                            <field name="date_to" class="oe_inline" readonly="state != 'draft'"/>
                        </div>
                        <field name="contract_id" 
                               domain="[('employee_id','=',employee_id),('date_start','&lt;=',date_to),'|',('date_end','&gt;=',date_from),('date_end','=',False)]" 
                               context="{'default_employee_id': employee_id}" 
                               readonly="state != 'draft'"/>
                        <field name="number" readonly="state != 'draft'"/>
                        <field name="struct_id" required="contract_id != False" readonly="state != 'draft'"/>
                        <field name="name" readonly="state != 'draft'"/>
                        <field name="credit_note" readonly="state != 'draft'"/>
                    </group>
                    <notebook>
                        <page string="Worked Days &amp; Inputs">
                            <separator string="Worked Days"/>
                            <field name="worked_days_line_ids">
                                <list string="Worked Days" editable="bottom">
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="number_of_days" sum="Total Days"/>
                                    <field name="number_of_hours"/>
                                    <field name="contract_id"/>
                                    <field name="sequence" invisible="1"/>
                                </list>
                                <form string="Worked Day">
                                    <group col="4">
                                        <field name="name"/>
                                        <field name="code"/>
                                        <field name="sequence" invisible="1"/>
                                        <field name="number_of_days"/>
                                        <field name="number_of_hours"/>
                                        <field name="contract_id"/>
                                    </group>
                                </form>
                            </field>
                            <separator string="Other Inputs"/>
                            <field name="input_line_ids" colspan="4" nolabel="1">
                                <list string="Input Data" editable="bottom">
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="amount"/>
                                    <field name="contract_id"/>
                                    <field name="sequence" invisible="1"/>
                                </list>
                                <form string="Payslip Input">
                                    <group col="4">
                                        <field name="name"/>
                                        <field name="code"/>
                                        <field name="sequence" invisible="1"/>
                                        <field name="amount"/>
                                        <field name="contract_id"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        
                        <!-- UPDATED: Salary Computation Page - No Sequence, Editable -->
                        <page string="Salary Computation">
                            <field name="line_ids" colspan="4" nolabel="1">
                                <list string="Salary Structure" editable="bottom" decoration-info="total == 0">
                                    <!-- Hidden fields -->
                                    <field name="sequence" invisible="1"/>
                                    <field name="salary_rule_id" invisible="1"/>
                                    <field name="amount_select" invisible="1"/>
                                    <field name="register_id" invisible="1"/>
                                    
                                    <!-- Visible and editable fields -->
                                    <field name="category_id" optional="hide"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="rate"/>
                                    <field name="amount"/>
                                    <field name="total" sum="Total"/>
                                </list>
                                <form string="Payslip Line">
                                    <group col="4">
                                        <field name="name"/>
                                        <field name="code"/>
                                        <field name="category_id"/>
                                        <field name="sequence" invisible="1"/>
                                        <field name="quantity"/>
                                        <field name="rate"/>
                                        <field name="amount"/>
                                        <field name="total"/>
                                        <field name="salary_rule_id"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        
                        <page string="Details By Category">
                            <field name="details_by_salary_rule_category" domain="[('appears_on_payslip', '=', True)]">
                                <list string="Payslip Lines" decoration-info="total == 0">
                                    <field name="category_id"/>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="total" sum="Total"/>
                                </list>
                            </field>
                        </page>
                        
                        <page string="Accounting Information">
                            <group>
                                <group string="Miscellaneous">
                                    <field name="company_id" groups="base.group_multi_company"/>
                                    <field name="payslip_run_id" domain="[('state','=','draft')]"/>
                                </group>
                                <group name="accounting" string="Accounting">
                                    <field name="paid" readonly="1"/>
                                </group>
                            </group>
                            <div colspan="4">
                                <field name="note" placeholder="Add an internal note..."/>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Payslip Search View -->
    <record id="view_hr_payslip_filter" model="ir.ui.view">
        <field name="name">hr.payslip.select</field>
        <field name="model">hr.payslip</field>
        <field name="arch" type="xml">
            <search string="Search Payslips">
                <field name="name" string="Payslips" filter_domain="['|',('name','ilike',self),('number','ilike',self)]"/>
                <field name="date_from"/>
                <field name="employee_id"/>
                <field name="payslip_run_id"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]" help="Draft Slip"/>
                <filter string="Done" name="done" domain="[('state','=','done')]" help="Done Slip"/>
                <filter string="Cancelled" name="cancel" domain="[('state','=','cancel')]" help="Cancelled Slip"/>
                <filter string="This Month" name="this_month" 
                        domain="[('date_from','&gt;=', context_today().replace(day=1).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="Employees" name="group_employee" context="{'group_by':'employee_id'}"/>
                <filter string="PaySlip Batch" name="group_run" context="{'group_by':'payslip_run_id'}"/>
                <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
            </search>
        </field>
    </record>

    <!-- Payslip Action -->
    <record id="action_view_hr_payslip_form" model="ir.actions.act_window">
        <field name="name">Employee Payslips</field>
        <field name="res_model">hr.payslip</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_hr_payslip_filter"/>
    </record>

    <menuitem action="action_view_hr_payslip_form" id="menu_department_tree" 
              parent="menu_hr_payroll_root" groups="bi_hr_payroll.group_hr_payroll_user"/>

    <!-- Employee Payslip Smart Button Action -->
    <record id="act_hr_employee_payslip_list" model="ir.actions.act_window">
        <field name="res_model">hr.payslip</field>
        <field name="name">Payslips</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_employee_id': [active_id], 'default_employee_id': active_id}</field>
    </record>

    <!-- Payslip Run Filter -->
    <record id="hr_payslip_run_filter" model="ir.ui.view">
        <field name="name">hr.payslip.run.search</field>
        <field name="model">hr.payslip.run</field>
        <field name="arch" type="xml">
            <search string="Search Payslip Batches">
                <field name="name" string="Payslip Batches"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter name="done_filter" string="Closed" domain="[('state','=','close')]"/>
            </search>
        </field>
    </record>

    <!-- Payslip Run Tree -->
    <record id="hr_payslip_run_tree" model="ir.ui.view">
        <field name="name">hr.payslip.run.tree</field>
        <field name="model">hr.payslip.run</field>
        <field name="arch" type="xml">
            <list string="Payslips Batches">
                <field name="name"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="credit_note"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Payslip Run Kanban -->
    <record id="hr_payslip_run_view_kanban" model="ir.ui.view">
        <field name="name">hr.payslip.run.kanban</field>
        <field name="model">hr.payslip.run</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_content oe_kanban_global_click">
                            <div class="row">
                                <div class="col-6">
                                    <strong><field name="name"/></strong>
                                </div>
                                <div class="col-6">
                                    <span class="float-right badge badge-secondary">
                                        <field name="state"/>
                                    </span>
                                </div>
                                <div class="col-12">
                                    <span>
                                        <field name="date_start"/> - <field name="date_end"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Payslip Run Form -->
    <record id="hr_payslip_run_form" model="ir.ui.view">
        <field name="name">hr.payslip.run.form</field>
        <field name="model">hr.payslip.run</field>
        <field name="arch" type="xml">
            <form string="Payslips Batches">
                <header>
                    <button name="close_payslip_run" type="object" string="Close" 
                            invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="%(action_hr_payslip_by_employees)d" type="action" 
                            string="Generate Payslips" class="oe_highlight"/>
                    <button string="Set to Draft" name="draft_payslip_run" type="object" 
                            invisible="state != 'close'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="state != 'draft'"/>
                        </h1>
                    </div>
                    <group col="4">
                        <label for="date_start" string="Period"/>
                        <div>
                            <field name="date_start" readonly="state != 'draft'" class="oe_inline"/> - 
                            <field name="date_end" readonly="state != 'draft'"/>
                        </div>
                        <field name="credit_note" readonly="state != 'draft'"/>
                    </group>
                    <separator string="Payslips"/>
                    <field name="slip_ids" readonly="state != 'draft'">
                        <list>
                            <field name="number"/>
                            <field name="employee_id"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="state" widget="badge"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Payslip Run Action -->
    <record id="action_hr_payslip_run_tree" model="ir.actions.act_window">
        <field name="name">Payslips Batches</field>
        <field name="res_model">hr.payslip.run</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="hr_payslip_run_filter"/>
    </record>
    
    <menuitem action="action_hr_payslip_run_tree" id="menu_hr_payslip_run" parent="menu_hr_payroll_root"/>

    <!-- Contribution Register Shortcut -->
    <record id="act_contribution_reg_payslip_lines" model="ir.actions.act_window">
        <field name="name">Payslip Lines</field>
        <field name="res_model">hr.payslip.line</field>
        <field name="binding_model_id" ref="model_hr_contribution_register"/>
        <field name="context">{'default_register_id': active_id, 'search_default_register_id': 1}</field>
        <field name="domain">[('register_id', '=', active_id)]</field>
    </record>

</odoo>