<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tax Table Tree View -->
    <record id="view_zim_tax_table_tree" model="ir.ui.view">
        <field name="name">zim.tax.table.tree</field>
        <field name="model">zim.tax.table</field>
        <field name="arch" type="xml">
            <list string="ZIMRA Tax Tables">
                <field name="currency_id"/>
                <field name="frequency"/>
                <field name="min_income"/>
                <field name="max_income"/>
                <field name="rate"/>
                <field name="deduction"/>
                <field name="effective_date"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Tax Table Form View -->
    <record id="view_zim_tax_table_form" model="ir.ui.view">
        <field name="name">zim.tax.table.form</field>
        <field name="model">zim.tax.table</field>
        <field name="arch" type="xml">
            <form string="Tax Table">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="currency_id" required="1"/>
                            <field name="frequency" required="1"/>
                            <field name="effective_date" required="1"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="min_income" required="1"/>
                            <field name="max_income"/>
                            <field name="rate" required="1"/>
                            <field name="deduction"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tax Table Search View -->
    <record id="view_zim_tax_table_search" model="ir.ui.view">
        <field name="name">zim.tax.table.search</field>
        <field name="model">zim.tax.table</field>
        <field name="arch" type="xml">
            <search string="Search Tax Tables">
                <field name="currency_id"/>
                <field name="frequency"/>
                <filter string="Active" name="filter_active" 
                        domain="[('active', '=', True)]"/>
                <filter string="Monthly" name="filter_monthly" 
                        domain="[('frequency', '=', 'monthly')]"/>
                <filter string="Weekly" name="filter_weekly" 
                        domain="[('frequency', '=', 'weekly')]"/>
                <filter string="Fortnightly" name="filter_fortnightly" 
                        domain="[('frequency', '=', 'fortnightly')]"/>
                <filter string="Daily" name="filter_daily" 
                        domain="[('frequency', '=', 'daily')]"/>
                <separator/>
                <filter string="Currency" name="group_currency" 
                        context="{'group_by': 'currency_id'}"/>
                <filter string="Frequency" name="group_frequency" 
                        context="{'group_by': 'frequency'}"/>
            </search>
        </field>
    </record>

    <!-- Tax Table Action -->
    <record id="action_zim_tax_table" model="ir.actions.act_window">
        <field name="name">ZIMRA Tax Tables</field>
        <field name="res_model">zim.tax.table</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_zim_tax_table_search"/>
    </record>

    <!-- Add to Payroll Configuration Menu -->
    <menuitem id="menu_zim_tax_tables"
              name="ZIMRA Tax Tables"
              parent="bi_hr_payroll.menu_hr_payroll_configuration"
              action="action_zim_tax_table"
              sequence="15"/>
</odoo>