<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="view_hr_employee_leave_off_days" model="ir.ui.view">
        <field name="name">hr.employee.leave.off.days</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority">60</field>
        <field name="arch" type="xml">
            
            <xpath expr="//notebook" position="inside">
                
                <page string="Leave &amp; Off Days" name="employee_leave_off">
                    
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-calendar-plus-o" type="object">
                            <div class="o_stat_info">
                                <span class="o_stat_value">Request</span>
                                <span class="o_stat_text">Leave</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" icon="fa-clock-o" type="object">
                            <div class="o_stat_info">
                                <span class="o_stat_value">Add</span>
                                <span class="o_stat_text">Off Day</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" icon="fa-calendar" type="object">
                            <div class="o_stat_info">
                                <span class="o_stat_value">View</span>
                                <span class="o_stat_text">Calendar</span>
                            </div>
                        </button>
                    </div>
                    
                    <group col="4">
                        <div style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); color: white; padding: 16px; border-radius: 8px; text-align: center;">
                            <div style="font-size: 32px; font-weight: bold;">24</div>
                            <div>Annual Leave Days</div>
                        </div>
                        <div style="background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%); color: white; padding: 16px; border-radius: 8px; text-align: center;">
                            <div style="font-size: 32px; font-weight: bold;">18</div>
                            <div>Days Taken</div>
                        </div>
                        <div style="background: linear-gradient(135deg, #17a2b8 0%, #6f42c1 100%); color: white; padding: 16px; border-radius: 8px; text-align: center;">
                            <div style="font-size: 32px; font-weight: bold;">6</div>
                            <div>Remaining</div>
                        </div>
                        <div style="background: linear-gradient(135deg, #6c757d 0%, #495057 100%); color: white; padding: 16px; border-radius: 8px; text-align: center;">
                            <div style="font-size: 32px; font-weight: bold;">5</div>
                            <div>Off Days (YTD)</div>
                        </div>
                    </group>
                    
                    <group string="Leave Balance">
                        <div style="overflow-x: auto;">
                            <table class="o_group o_inner_group" style="width: 100%;">
                                <thead>
                                    <tr style="background: #667eea; color: white;">
                                        <th style="padding: 10px;">Leave Type</th>
                                        <th style="padding: 10px; text-align: center;">Entitled</th>
                                        <th style="padding: 10px; text-align: center;">Taken</th>
                                        <th style="padding: 10px; text-align: center;">Planned</th>
                                        <th style="padding: 10px; text-align: center;">Remaining</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td>Annual Leave</td><td style="text-align: center;">24</td><td style="text-align: center;">18</td><td style="text-align: center;">3</td><td style="text-align: center;">6</td></tr>
                                    <tr><td>Sick Leave</td><td style="text-align: center;">12</td><td style="text-align: center;">2</td><td style="text-align: center;">0</td><td style="text-align: center;">10</td></tr>
                                    <tr><td>Maternity Leave</td><td style="text-align: center;">90</td><td style="text-align: center;">0</td><td style="text-align: center;">0</td><td style="text-align: center;">90</td></tr>
                                    <tr><td>Family Responsibility</td><td style="text-align: center;">5</td><td style="text-align: center;">0</td><td style="text-align: center;">0</td><td style="text-align: center;">5</td></tr>
                                    <tr><td>Study Leave</td><td style="text-align: center;">10</td><td style="text-align: center;">0</td><td style="text-align: center;">0</td><td style="text-align: center;">10</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </group>
                    
                    <group string="Recent Leave Requests">
                        <div style="overflow-x: auto;">
                            <table class="o_group o_inner_group" style="width: 100%;">
                                <thead>
                                    <tr style="background: #28a745; color: white;">
                                        <th style="padding: 10px;">Type</th>
                                        <th style="padding: 10px;">From</th>
                                        <th style="padding: 10px;">To</th>
                                        <th style="padding: 10px; text-align: center;">Days</th>
                                        <th style="padding: 10px;">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td>Annual Leave</td><td>Dec 20, 2026</td><td>Dec 31, 2026</td><td style="text-align: center;">12</td><td><span style="background: #ffc107; padding: 4px 8px; border-radius: 4px;">Pending</span></td></tr>
                                    <tr><td>Annual Leave</td><td>Jul 15, 2026</td><td>Jul 20, 2026</td><td style="text-align: center;">6</td><td><span style="background: #28a745; color: white; padding: 4px 8px; border-radius: 4px;">Approved</span></td></tr>
                                    <tr><td>Sick Leave</td><td>May 5, 2026</td><td>May 6, 2026</td><td style="text-align: center;">2</td><td><span style="background: #28a745; color: white; padding: 4px 8px; border-radius: 4px;">Approved</span></td></tr>
                                    <tr><td>Annual Leave</td><td>Mar 10, 2026</td><td>Mar 19, 2026</td><td style="text-align: center;">10</td><td><span style="background: #28a745; color: white; padding: 4px 8px; border-radius: 4px;">Approved</span></td></tr>
                                </tbody>
                            </table>
                        </div>
                    </group>
                    
                    <group string="Off Days &amp; Public Holidays">
                        <div style="overflow-x: auto;">
                            <table class="o_group o_inner_group" style="width: 100%;">
                                <thead>
                                    <tr style="background: #fd7e14; color: white;">
                                        <th style="padding: 10px;">Date</th>
                                        <th style="padding: 10px;">Day</th>
                                        <th style="padding: 10px;">Type</th>
                                        <th style="padding: 10px;">Description</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td>Apr 18, 2026</td><td>Friday</td><td>Public Holiday</td><td>Good Friday</td></tr>
                                    <tr><td>Apr 21, 2026</td><td>Monday</td><td>Public Holiday</td><td>Easter Monday</td></tr>
                                    <tr><td>May 1, 2026</td><td>Thursday</td><td>Public Holiday</td><td>Workers' Day</td></tr>
                                    <tr><td>May 25, 2026</td><td>Monday</td><td>Public Holiday</td><td>Africa Day</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </group>
                    
                </page>
                
            </xpath>
            
        </field>
    </record>

</odoo>