                        </table>
                    </div>
                    
                    <!-- Net Salary Summary Cards -->
                    <div class="oe_clearfix mt16"/>
                    <div class="row">
                        <div class="col-4">
                            <div class="alert alert-success text-center" role="alert">
                                <h5>Gross Earnings</h5>
                                <h3 style="color: #17a2b8;">$8,250.00</h3>
                                <small class="text-muted">ZWG 53,625.00</small>
