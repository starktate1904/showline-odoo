<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Employee Form View - Add Earnings, Deductions, and Summary Tabs (UI Only) -->
    <record id="view_hr_employee_form_salary_tabs" model="ir.ui.view">
        <field name="name">hr.employee.form.salary.tabs</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            
            <notebook position="inside">
                
                <!-- EARNINGS TAB -->
                <page string="Earnings" name="employee_earnings">
                    
                    <div class="o_horizontal_separator">Earnings &amp; Allowances</div>
                    
                    <!-- Static Earnings Table -->
                    <div class="table-responsive">
                        <table class="o_group o_inner_group salary-summary-table">
                            <thead>
                                <tr style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                                    <th style="padding: 12px 15px;">Component</th>
                                    <th style="padding: 12px 15px;">Category</th>
                                    <th style="padding: 12px 15px; text-align: right;">Amount (USD)</th>
                                    <th style="padding: 12px 15px; text-align: right;">Amount (ZWG)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr style="color: #28a745;">
                                    <td style="padding: 10px 15px;"><strong>Basic Salary</strong></td>
                                    <td style="padding: 10px 15px;">Basic</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #17a2b8;">$6,500.00</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #6c757d;">ZWG 42,250.00</td>
                                </tr>
                                <tr style="color: #28a745;">
                                    <td style="padding: 10px 15px;"><strong>Housing Allowance</strong></td>
                                    <td style="padding: 10px 15px;">Allowances</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #17a2b8;">$1,200.00</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #6c757d;">ZWG 7,800.00</td>
                                </tr>
                                <tr style="color: #28a745;">
                                    <td style="padding: 10px 15px;"><strong>Transport Allowance</strong></td>
                                    <td style="padding: 10px 15px;">Allowances</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #17a2b8;">$350.00</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #6c757d;">ZWG 2,275.00</td>
                                </tr>
                                <tr style="color: #28a745;">
                                    <td style="padding: 10px 15px;"><strong>Fuel Allowance</strong></td>
                                    <td style="padding: 10px 15px;">Allowances</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #17a2b8;">$200.00</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #6c757d;">ZWG 1,300.00</td>
                                </tr>
                                <tr style="background-color: #e9ecef; font-weight: 700;">
                                    <td colspan="2" style="padding: 10px 15px;"><strong>Total Earnings</strong></td>
                                    <td style="padding: 10px 15px; text-align: right; color: #17a2b8;"><strong>$8,250.00</strong></td>
                                    <td style="padding: 10px 15px; text-align: right; color: #6c757d;"><strong>ZWG 53,625.00</strong></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    
                    <div class="oe_clearfix"/>
                    
                    <!-- Legend -->
                    <group string="Legend" class="oe_inline mt16">
                        <div class="text-muted">
                            <span class="badge" style="background-color: #28a745; padding: 5px 10px;">■</span> Earning Component
                            <span class="badge ml-3" style="background-color: #17a2b8; padding: 5px 10px;">■</span> Base Currency (USD)
                            <span class="badge ml-3" style="background-color: #6c757d; padding: 5px 10px;">■</span> Local Currency (ZWG)
                        </div>
                    </group>
                    
                    <div class="alert alert-info mt16" role="alert">
                        <i class="fa fa-info-circle"/> Earnings are based on the employee's assigned salary structure.
                    </div>
                    
                </page>
                
                <!-- DEDUCTIONS TAB -->
                <page string="Deductions" name="employee_deductions">
                    
                    <div class="o_horizontal_separator">Deductions &amp; Taxes</div>
                    
                    <!-- Static Deductions Table -->
                    <div class="table-responsive">
                        <table class="o_group o_inner_group salary-summary-table">
                            <thead>
                                <tr style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                                    <th style="padding: 12px 15px;">Component</th>
                                    <th style="padding: 12px 15px;">Category</th>
                                    <th style="padding: 12px 15px; text-align: right;">Amount (USD)</th>
                                    <th style="padding: 12px 15px; text-align: right;">Amount (ZWG)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr style="color: #dc3545;">
                                    <td style="padding: 10px 15px;"><strong>PAYE (Income Tax)</strong></td>
                                    <td style="padding: 10px 15px;">Tax</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #17a2b8;">$1,825.00</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #6c757d;">ZWG 11,862.50</td>
                                </tr>
                                <tr style="color: #dc3545;">
                                    <td style="padding: 10px 15px;"><strong>NSSA (Employee)</strong></td>
                                    <td style="padding: 10px 15px;">NSSA</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #17a2b8;">$31.50</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #6c757d;">ZWG 204.75</td>
                                </tr>
                                <tr style="color: #dc3545;">
                                    <td style="padding: 10px 15px;"><strong>AIDS Levy</strong></td>
                                    <td style="padding: 10px 15px;">Tax</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #17a2b8;">$54.75</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #6c757d;">ZWG 355.88</td>
                                </tr>
                                <tr style="color: #dc3545;">
                                    <td style="padding: 10px 15px;"><strong>NEC Contribution</strong></td>
                                    <td style="padding: 10px 15px;">NEC</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #17a2b8;">$97.50</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #6c757d;">ZWG 633.75</td>
                                </tr>
                                <tr style="color: #dc3545;">
                                    <td style="padding: 10px 15px;"><strong>Medical Aid</strong></td>
                                    <td style="padding: 10px 15px;">Medical Aid</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #17a2b8;">$150.00</td>
                                    <td style="padding: 10px 15px; text-align: right; color: #6c757d;">ZWG 975.00</td>
                                </tr>
                                <tr style="background-color: #e9ecef; font-weight: 700;">
                                    <td colspan="2" style="padding: 10px 15px;"><strong>Total Deductions</strong></td>
                                    <td style="padding: 10px 15px; text-align: right; color: #17a2b8;"><strong>$2,158.75</strong></td>
                                    <td style="padding: 10px 15px; text-align: right; color: #6c757d;"><strong>ZWG 14,031.88</strong></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    
                    <div class="oe_clearfix"/>
                    
                    <!-- Legend -->
                    <group string="Legend" class="oe_inline mt16">
                        <div class="text-muted">
                            <span class="badge" style="background-color: #dc3545; padding: 5px 10px;">■</span> Deduction Component
                            <span class="badge ml-3" style="background-color: #17a2b8; padding: 5px 10px;">■</span> Base Currency (USD)
                            <span class="badge ml-3" style="background-color: #6c757d; padding: 5px 10px;">■</span> Local Currency (ZWG)
                        </div>
                    </group>
                    
                </page>
                
