<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <record id="leave_type_annual" model="havano.leave.type">
            <field name="name">Annual Leave</field>
            <field name="code">ANNUAL</field>
            <field name="sequence">10</field>
            <field name="leave_category">annual</field>
            <field name="accrual_enabled">True</field>
            <field name="accrual_days">2.5</field>
            <field name="accrual_frequency">monthly</field>
            <field name="max_days">30.0</field>
            <field name="allow_encashment">True</field>
            <field name="allow_carry_over">True</field>
            <field name="max_carry_over_days">5.0</field>
            <field name="paid_leave">True</field>
        </record>

        <record id="leave_type_sick" model="havano.leave.type">
            <field name="name">Sick Leave</field>
            <field name="code">SICK</field>
            <field name="sequence">20</field>
            <field name="leave_category">sick</field>
            <field name="max_days">12.0</field>
            <field name="paid_leave">True</field>
        </record>

        <record id="leave_type_maternity" model="havano.leave.type">
            <field name="name">Maternity Leave</field>
            <field name="code">MATERNITY</field>
            <field name="sequence">30</field>
            <field name="leave_category">maternity</field>
            <field name="max_days">90.0</field>
            <field name="gender_restriction">female</field>
            <field name="paid_leave">True</field>
        </record>

        <record id="leave_type_study" model="havano.leave.type">
            <field name="name">Study Leave</field>
            <field name="code">STUDY</field>
            <field name="sequence">40</field>
            <field name="leave_category">study</field>
            <field name="max_days">10.0</field>
            <field name="paid_leave">True</field>
        </record>

        <record id="leave_type_family" model="havano.leave.type">
            <field name="name">Family Responsibility</field>
            <field name="code">FAMILY</field>
            <field name="sequence">50</field>
            <field name="leave_category">family</field>
            <field name="max_days">5.0</field>
            <field name="paid_leave">True</field>
        </record>

        <record id="leave_type_unpaid" model="havano.leave.type">
            <field name="name">Unpaid Leave</field>
            <field name="code">UNPAID</field>
            <field name="sequence">60</field>
            <field name="leave_category">unpaid</field>
            <field name="paid_leave">False</field>
        </record>

    </data>
</odoo>