<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- List View -->
    <record id="view_zimra_tax_table_list" model="ir.ui.view">
        <field name="name">zimra.tax.table.list</field>
        <field name="model">zimra.tax.table</field>
        <field name="arch" type="xml">
            <list string="ZIMRA Tax Tables" editable="bottom">
                <field name="currency_id" required="1"/>
                <field name="frequency" required="1"/>
                <field name="min_income" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="max_income" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="rate"/>
                <field name="deduction" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="effective_date"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    
    <!-- Form View -->
    <record id="view_zimra_tax_table_form" model="ir.ui.view">
        <field name="name">zimra.tax.table.form</field>
        <field name="model">zimra.tax.table</field>
        <field name="arch" type="xml">
            <form string="Tax Table">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="currency_id" required="1"/>
                            <field name="frequency" required="1"/>
                            <field name="effective_date" required="1"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="min_income" required="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="max_income" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="rate" required="1"/>
                            <field name="deduction" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- Search View -->
    <record id="view_zimra_tax_table_search" model="ir.ui.view">
        <field name="name">zimra.tax.table.search</field>
        <field name="model">zimra.tax.table</field>
        <field name="arch" type="xml">
            <search string="Search Tax Tables">
                <field name="currency_id"/>
                <field name="frequency"/>
                
                <filter string="Active" name="filter_active" domain="[('active', '=', True)]"/>
                
                <separator/>
                <filter string="USD" name="filter_usd" domain="[('currency_id.name', '=', 'USD')]"/>
                <filter string="ZWG" name="filter_zwg" domain="[('currency_id.name', '=', 'ZWG')]"/>
                
                <separator/>
                <filter string="Monthly" name="filter_monthly" domain="[('frequency', '=', 'monthly')]"/>
                <filter string="Weekly" name="filter_weekly" domain="[('frequency', '=', 'weekly')]"/>
                <filter string="Fortnightly" name="filter_fortnightly" domain="[('frequency', '=', 'fortnightly')]"/>
                <filter string="Daily" name="filter_daily" domain="[('frequency', '=', 'daily')]"/>
                
                <separator/>
                <filter string="Currency" name="group_currency" context="{'group_by': 'currency_id'}"/>
                <filter string="Frequency" name="group_frequency" context="{'group_by': 'frequency'}"/>
            </search>
        </field>
    </record>
    
    <!-- Action -->
    <record id="action_zimra_tax_table" model="ir.actions.act_window">
        <field name="name">ZIMRA Tax Tables</field>
        <field name="res_model">zimra.tax.table</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_zimra_tax_table_search"/>
    </record>
    
    <!-- Menu -->
    <menuitem id="menu_zimra_tax_tables"
              name="ZIMRA Tax Tables"
              parent="havano_payroll.menu_havano_payroll_config"
              action="action_zimra_tax_table"
              sequence="20"/>
    
</odoo>