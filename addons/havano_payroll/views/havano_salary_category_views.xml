<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Category List View -->
    <record id="view_havano_salary_category_list" model="ir.ui.view">
        <field name="name">havano.salary.category.list</field>
        <field name="model">havano.salary.category</field>
        <field name="arch" type="xml">
            <list string="Salary Categories" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="category_type" widget="badge"/>
                <field name="calculation_order"/>
                <field name="is_allowable_deduction" widget="boolean_toggle"/>
                <field name="is_tax_credit" widget="boolean_toggle"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    
    <!-- Category Form View -->
    <record id="view_havano_salary_category_form" model="ir.ui.view">
        <field name="name">havano.salary.category.form</field>
        <field name="model">havano.salary.category</field>
        <field name="arch" type="xml">
            <form string="Salary Category">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Category Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="category_type"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                            <field name="calculation_order"/>
                        </group>
                    </group>
                    
                    <group string="Tax Behavior">
                        <group>
                            <field name="affects_taxable_income"/>
                            <field name="is_allowable_deduction"/>
                        </group>
                        <group>
                            <field name="is_tax_credit"/>
                            <field name="tax_credit_percentage" 
                                   invisible="not is_tax_credit"
                                   widget="percentage"/>
                        </group>
                    </group>
                    
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- Action -->
    <record id="action_havano_salary_category" model="ir.actions.act_window">
        <field name="name">Salary Categories</field>
        <field name="res_model">havano.salary.category</field>
        <field name="view_mode">list,form</field>
    </record>
    
    <!-- Menu -->
              name="Salary Categories"
              parent="menu_havano_payroll_config"
              action="action_havano_salary_category"
              sequence="5"/>
    
</odoo>