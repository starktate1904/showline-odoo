<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_form_havano_payroll" model="ir.ui.view">
        <field name="name">hr.employee.form.havano.payroll</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <notebook position="inside">
                <!-- EARNINGS TAB -->
                <page string="Earnings">
                    <group><field name="secondary_currency_id" string="Secondary Currency"/></group>
                    <group string="Earnings &amp; Allowances">
                        <field name="earnings_ids" context="{'default_currency_id': currency_id}">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="component_id" domain="[('component_type', '=', 'earning')]" string="Component" required="1"/>
                                <field name="component_category" string="Category" readonly="1"/>
                                <field name="amount" string="Amount" sum="Total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="secondary_amount" string="Sec Amount" sum="Total Sec" widget="monetary" options="{'currency_field': 'secondary_currency_id'}"/>
                            </list>
                        </field>
                    </group>
                    <group>
                        <group><field name="total_earnings" widget="monetary" options="{'currency_field': 'currency_id'}"/></group>
                        <group><field name="secondary_total_earnings" widget="monetary" options="{'currency_field': 'secondary_currency_id'}"/></group>
                    </group>
                </page>
                <!-- DEDUCTIONS TAB -->
                <page string="Deductions">
                    <div class="oe_button_box">
                        <button name="action_calculate_all_deductions" type="object" string="Calculate All" class="oe_stat_button" icon="fa-calculator"/>
                    </div>
                    <group string="Deductions &amp; Taxes">
                        <field name="deduction_ids" context="{'default_currency_id': currency_id}">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="component_id" string="Component" required="1"/>
                                <field name="component_category" string="Category" readonly="1"/>
                                <field name="amount" string="Amount" sum="Total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="secondary_amount" string="Sec Amount" sum="Total Sec" widget="monetary" options="{'currency_field': 'secondary_currency_id'}"/>
                            </list>
                        </field>
                    </group>
                    <group>
                        <group><field name="total_deductions" widget="monetary" options="{'currency_field': 'currency_id'}"/></group>
                        <group><field name="secondary_total_deductions" widget="monetary" options="{'currency_field': 'secondary_currency_id'}"/></group>
                    </group>
                </page>
                <!-- ==================== SALARY SUMMARY TAB ==================== -->
                <page string="Salary Summary">
                    
                    <!-- GROSS EARNINGS -->
                    <group string="Gross Earnings">
                        <group>
                            <field name="total_earnings" string="Total Earnings (Primary)" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </group>
                        <group>
                            <field name="secondary_total_earnings" string="Total Earnings (Secondary)" widget="monetary" options="{'currency_field': 'secondary_currency_id'}"/>
                        </group>
                    </group>

                    <!-- ALLOWABLE DEDUCTIONS -->
                    <group string="Allowable Deductions">
                        <group>
                            <field name="total_allowable_deductions" string="Total Allowable Deductions (Primary)"/>
                        </group>
                        <group>
                            <field name="secondary_allowable_deductions" string="Total Allowable Deductions (Secondary)"/>
                        </group>
                    </group>

                    <!-- TAXABLE INCOME -->
                    <group string="Taxable Income">
                        <group>
                            <field name="taxable_income" string="Taxable Income (Primary)"/>
                        </group>
                        <group>
                            <field name="secondary_taxable_income" string="Taxable Income (Secondary)"/>
                        </group>
                    </group>
                    
                    <!-- TOTAL DEDUCTIONS -->
                    <group string="Total Deductions">
                        <group>
                            <field name="total_deductions" string="Total Deductions (Primary)" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </group>
                        <group>
                            <field name="secondary_total_deductions" string="Total Deductions (Secondary)" widget="monetary" options="{'currency_field': 'secondary_currency_id'}"/>
                        </group>
                    </group>
                    
                    <!-- NET SALARY -->
                    <group string="Net Salary">
                        <group>
                            <field name="net_salary" string="Net Salary (Primary)" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </group>
                        <group>
                            <field name="secondary_net_salary" string="Net Salary (Secondary)" widget="monetary" options="{'currency_field': 'secondary_currency_id'}"/>
                        </group>
                    </group>
                    
                </page>
                <!-- LEAVE & OFF DAYS TAB -->
                <page string="Leave &amp; Off Days">
                    <div class="oe_button_box">
                        <button name="%(hr_holidays.hr_leave_action_new_request)d" type="action" string="Request Time Off" class="oe_stat_button" icon="fa-calendar-plus-o" context="{'default_employee_id': id}"/>
                        <button name="%(hr_holidays.hr_leave_action_my)d" type="action" string="All Time Off" class="oe_stat_button" icon="fa-calendar-check-o"/>
                        <button name="%(action_havano_leave_encashment)d" type="action" string="Encash Leave" class="oe_stat_button" icon="fa-money" context="{'default_employee_id': id}"/>
                    </div>
                    <group string="Leave Encashments" class="mt16">
                        <field name="encashment_ids">
                            <list>
                                <field name="date_requested"/>
                                <field name="number_of_days"/>
                                <field name="total_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="state" widget="badge"/>
                            </list>
                        </field>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
